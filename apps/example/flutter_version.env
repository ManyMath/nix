# Run scripts/fetch-flutter.sh (macOS) or scripts/fetch-flutter-linux.sh (Linux) after changing.
# Web: run scripts/fetch-flutter-web.sh -- it auto-detects the host OS and reuses the hashes below.
FLUTTER_VERSION="3.38.2"
FLUTTER_CHANNEL="stable"

# Per-arch SHA-256 hashes for macOS (fetch-flutter.sh prints the computed hash).
FLUTTER_SHA256_X64=""
FLUTTER_SHA256_ARM64=""

# Per-arch SHA-256 hashes for Linux (fetch-flutter-linux.sh prints the computed hash).
FLUTTER_SHA256_LINUX_X64="9d9c0dcb9180c6dfb176ed5dfdde4fef9a5899f966331c365f18f64262a8b777"
FLUTTER_SHA256_LINUX_ARM64=""
